{
  "name": "@lyrolab/frontend-shared",
  "version": "0.0.0-semantically-released",
  "description": "Shared frontend ESLint/Prettier/TypeScript presets and architecture guidelines for Lyrolab web apps.",
  "type": "module",
  "private": false,
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lyrolab/frontend-shared.git"
  },
  "files": [
    "src",
    "GUIDELINES.md"
  ],
  "exports": {
    "./eslint": {
      "types": "./src/eslint/index.d.ts",
      "import": "./src/eslint/index.js"
    },
    "./prettier": "./src/prettier/index.json",
    "./tsconfig": "./src/tsconfig/base.json",
    "./guidelines": "./GUIDELINES.md"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.js",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3",
    "typescript": ">=5"
  },
  "dependencies": {
    "@eslint/js": "^9.17.0",
    "@tanstack/eslint-plugin-query": "^5.62.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript-eslint": "^8.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "semantic-release": "^24.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "typescript": "^5.7.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,mjs,json,md}": "prettier --write"
  }
}
